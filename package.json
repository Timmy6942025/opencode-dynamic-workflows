{
  "name": "oc-dw",
  "version": "0.3.2",
  "description": "Seamless dynamic workflow orchestration for OpenCode. Install, setup, use inside OpenCode.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "license": "MIT",
  "bin": {
    "oc-dw": "dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs"
    },
    "./server": {
      "types": "./dist/src/plugin.d.ts",
      "import": "./dist/src/plugin.js",
      "require": "./dist/src/plugin.cjs"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild dist/src/index.js --bundle --platform=node --format=cjs --outfile=dist/src/index.cjs --target=node20 && esbuild dist/src/plugin.js --bundle --platform=node --format=cjs --outfile=dist/src/plugin.cjs --target=node20",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "qa": "npm run build && node --test dist/test/*.test.js && node test/live-opencode-test.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.12",
    "@opencode-ai/sdk": "^1.15.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "opencode": ">=1.15.0"
  },
  "keywords": [
    "opencode",
    "dynamic-workflows",
    "claude-code",
    "ai",
    "orchestration",
    "multi-agent",
    "plugin"
  ],
  "author": "Timmy6942025",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timmy6942025/opencode-dynamic-workflows.git"
  },
  "bugs": {
    "url": "https://github.com/Timmy6942025/opencode-dynamic-workflows/issues"
  },
  "homepage": "https://github.com/Timmy6942025/opencode-dynamic-workflows#readme"
}
